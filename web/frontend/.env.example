# Frontend API
VITE_API_BASE_URL=http://localhost:5001/api/v1

# Demo controls are hidden in production unless explicitly enabled.
VITE_SHOW_DEMO_CONTROLS=false

# Production should use real API data only.
# In dev, set this to true when you want to test strict no-sample behavior.
VITE_STRICT_API=false

# Optional escape hatch for visual UI work only. Do not enable in production.
VITE_USE_SAMPLE_FALLBACK=false
