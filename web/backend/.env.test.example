# Test server
PORT=5001
NODE_ENV=test

# MongoDB test database
MONGODB_URI=mongodb://localhost:27017/wdp_research_test

# Redis is disabled in automated tests by default
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# JWT test secrets
JWT_SECRET=test_jwt_secret_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=1d

# AI / LLM disabled or mocked in tests unless explicitly enabled
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Academic source APIs
OPENALEX_API_URL=https://api.openalex.org
OPENALEX_MAILTO=test@example.com
EXTERNAL_API_TIMEOUT_MS=90000
SEMANTIC_SCHOLAR_API_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_API_URL=https://api.crossref.org
CROSSREF_MAILTO=test@example.com
IEEE_API_URL=https://ieeexploreapi.ieee.org
IEEE_API_KEY=
IEEE_XPLORE_API_KEY=
EXA_API_URL=https://api.exa.ai
EXA_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Email / SMTP disabled in tests
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ResearchTrends <no-reply@example.com>
